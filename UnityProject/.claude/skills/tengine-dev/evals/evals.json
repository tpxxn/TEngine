      "expected_patterns": [
        "GameEventHelper.Init()",
        "GameApp.Entrance",
        "Source Generator",
        "[EventInterface(EEventGroup"
      ],
      "forbidden_patterns": [
        "UnRegisterAll"
      ]
    },
    {
      "id": 3,
      "name": "resource-lifecycle",
      "prompt": "我需要在热更代码中加载一个配置文件（TextAsset），解析后缓存数据。窗口关闭时释放资源。请给出完整的资源加载和释放模式代码。",
      "expected_patterns": [
        "LoadAssetAsync<TextAsset>",
        "UnloadAsset",
        "OnDestroy",
        "CancellationToken"
      ],
      "forbidden_patterns": [
        "Resources.Load",
        "StartCoroutine",
        "LoadAssetAsync<Sprite>"
      ]
    },
    {
      "id": 4,
      "name": "set-sprite-callback",
      "prompt": "我需要在 TEngine 中加载一个 Sprite 到 Image 上，加载完成后执行一些逻辑。请给出使用 SetSprite 的代码。",
