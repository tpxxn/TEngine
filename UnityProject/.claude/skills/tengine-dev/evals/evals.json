      "name": "ui-window-lifecycle",
      "prompt": "在 TEngine 中创建一个背包 UI（BagUI），显示物品列表，每个物品有图标和名称。点击物品弹出详情。请帮我写完整的 UIWindow 代码。",
      "expected_patterns": [
        "[Window(UILayer.UI",
        "class BagUI : UIWindow",
        "override void ScriptGenerator()",
        "override void RegisterEvent()",
        "override void OnCreate()",
        "override void OnRefresh()",
        "FindChildComponent",
        "AddUIEvent"
      ],
      "forbidden_patterns": [
        "void OnClose(",
        "Coroutine",
        "StartCoroutine",
        "Resources.Load"
      ]
    },
    {
      "id": 2,
      "name": "event-interface-usage",
